# ============================================================================
# Inventra POS — Backend Environment Variables
# ============================================================================

# Server port (default: 5000)
PORT=5000

# ───────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB Atlas
# ───────────────────────────────────────────────────────────────────────────

MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/inventra

# ───────────────────────────────────────────────────────────────────────────
# JWT — Authentication Tokens
# ───────────────────────────────────────────────────────────────────────────

JWT_SECRET=your_long_random_secret_key_here_at_least_32_characters_long

# Token expiry (format: 7d, 24h, 1000 for milliseconds)
JWT_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────────────────────
# CLOUDINARY — Image Storage & CDN
# ───────────────────────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ───────────────────────────────────────────────────────────────────────────
# SUPERADMIN — Auto-Seed Configuration
# ───────────────────────────────────────────────────────────────────────────

# Auto-created on first server start (if user doesn't exist)
# You can login with these credentials after first start
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=super@inventra.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# ───────────────────────────────────────────────────────────────────────────
# EMAIL — SMTP Configuration (Gmail)
# ───────────────────────────────────────────────────────────────────────────


EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication (if not done)
# 3. Go to App passwords
# 4. Select Mail + Windows Computer
# 5. Copy the 16-character password
#
EMAIL_PASS=your_16char_app_password

# Sender email (can be same as EMAIL_USER)
EMAIL_FROM=your_gmail@gmail.com

# Sender name (appears in email "From" field)
EMAIL_FROM_NAME=Inventra POS

# ───────────────────────────────────────────────────────────────────────────
# FRONTEND — URL Configuration
# ───────────────────────────────────────────────────────────────────────────

FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────────────────────
# SQLite — Local Offline Database (Electron)
# ───────────────────────────────────────────────────────────────────────────

# Path to SQLite database file (for Electron desktop app)
# Default: ./inventra.db (creates in root directory)
#
SQLITE_DB=./inventra.db

